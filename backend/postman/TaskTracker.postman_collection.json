{
  "info": {
    "_postman_id": "6eb03ca2-2c05-4b9d-bd82-ca275b0d0d7d",
    "name": "Task Tracker API",
    "description": "REST API for the Task Tracker application. Import the companion 'Task Tracker - Local' environment before running.\n\nRun the folders top to bottom (Collection Runner respects this order): Auth > Projects > Tasks > AI > Validation Errors (Zod) > Error Scenarios > Cleanup > Health Check. Projects > Create Project stores {{projectId}}, which Tasks and Error Scenarios both depend on — Cleanup > Delete Project is deliberately last since it cascades and deletes that project's tasks too. Switch to Auth > Login as Admin to test cross-user visibility.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{$randomEmail}}\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Registers a new user. Always created with role USER. Uses a random email each run to avoid 409 conflicts."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has user with USER role', function () {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data.user).to.have.property('id');",
                  "  pm.expect(data.user.role).to.eql('USER');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Alice (seeded user)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Logs in as the seeded regular user and stores accessToken/refreshToken/userId in the environment for the Projects/Tasks folders to use."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "{",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('accessToken', data.accessToken);",
                  "  pm.environment.set('refreshToken', data.refreshToken);",
                  "  pm.environment.set('userId', data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Admin (seeded user)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Run instead of 'Login as Alice' to test admin-only cross-user visibility. Overwrites {{accessToken}} used by the Projects/Tasks folders, and also stores it separately in {{adminAccessToken}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "{",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('accessToken', data.accessToken);",
                  "  pm.environment.set('adminAccessToken', data.accessToken);",
                  "  pm.environment.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Exchanges the stored refresh token for a new access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "{",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('accessToken', data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
