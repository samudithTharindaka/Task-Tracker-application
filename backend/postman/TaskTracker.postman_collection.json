            "description": "ownerId is always set server-side to the authenticated user, regardless of what you send in the body. projectId is required and must be a project you own (run Projects > Create Project first)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "{",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('taskId', data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Task by Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks",
                "{{taskId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returned task matches taskId', function () {",
                  "  pm.expect(pm.response.json().id).to.eql(pm.environment.get('taskId'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"TEST\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks",
                "{{taskId}}"
              ]
            },
            "description": "Valid status values: TODO, IN_PROGRESS, TEST, DONE. A task can also be moved to a different project you own by sending projectId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Status was updated', function () {",
                  "  pm.expect(pm.response.json().status).to.eql('TEST');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks",
                "{{taskId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 204', function () {",
                  "  pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Chat",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/chat",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ai",
                "chat"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"What's due this week?\",\n  \"history\": []\n}"
            },
            "description": "Conversational assistant that can search/create/update the tasks and projects the caller has access to. Deletes always come back as a pendingDelete for the client to confirm via the existing DELETE /tasks/{id} — the assistant never deletes directly. Returns 503 if OPENAI_API_KEY is not configured on the server, or 502 if the AI provider itself errors (e.g. rate limited)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200, 502, or 503 (200 = success, 502 = AI provider errored e.g. rate limited, 503 = AI not configured on this server)', function () {",
                  "  pm.expect([200, 502, 503]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Response has the expected shape', function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.have.property('reply');",
                  "    pm.expect(data).to.have.property('mutated');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
