{
  "info": {
    "_postman_id": "6eb03ca2-2c05-4b9d-bd82-ca275b0d0d7d",
    "name": "Task Tracker API",
    "description": "REST API for the Task Tracker application. Import the companion 'Task Tracker - Local' environment before running.\n\nRun the folders top to bottom (Collection Runner respects this order): Auth > Projects > Tasks > Error Scenarios > Cleanup > Health Check. Projects > Create Project stores {{projectId}}, which Tasks and Error Scenarios both depend on — Cleanup > Delete Project is deliberately last since it cascades and deletes that project's tasks too. Switch to Auth > Login as Admin to test cross-user visibility.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{$randomEmail}}\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "description": "Registers a new user. Always created with role USER. Uses a random email each run to avoid 409 conflicts."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has user with USER role', function () {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data.user).to.have.property('id');",
                  "  pm.expect(data.user.role).to.eql('USER');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Alice (seeded user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Logs in as the seeded regular user and stores accessToken/refreshToken/userId in the environment for the Projects/Tasks folders to use."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "{",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('accessToken', data.accessToken);",
                  "  pm.environment.set('refreshToken', data.refreshToken);",
                  "  pm.environment.set('userId', data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Admin (seeded user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Run instead of 'Login as Alice' to test admin-only cross-user visibility. Overwrites {{accessToken}} used by the Projects/Tasks folders, and also stores it separately in {{adminAccessToken}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "{",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('accessToken', data.accessToken);",
                  "  pm.environment.set('adminAccessToken', data.accessToken);",
                  "  pm.environment.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "description": "Exchanges the stored refresh token for a new access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "{",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('accessToken', data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] },
            "description": "USER role only ever sees their own projects; ADMIN sees all."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has a value array', function () {",
                  "  pm.expect(pm.response.json().value).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Board\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] },
            "description": "ownerId is always set server-side to the authenticated user. Stores the new project's id in {{projectId}} for the Tasks folder to use."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "{",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('projectId', data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Project by Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returned project matches projectId', function () {",
                  "  pm.expect(pm.response.json().id).to.eql(pm.environment.get('projectId'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Project (Rename)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Board (renamed)\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Name was updated', function () {",
                  "  pm.expect(pm.response.json().name).to.eql('My Board (renamed)');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?$top=10&$skip=0&$orderby=dueDate desc",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "$top", "value": "10" },
                { "key": "$skip", "value": "0" },
                { "key": "$orderby", "value": "dueDate desc" }
              ]
            },
            "description": "USER role only ever sees their own tasks server-side, even if you add an ownerId filter below."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has OData envelope', function () {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property('@odata.count');",
                  "  pm.expect(data.value).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Tasks - Filter by Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?$filter=status eq 'DONE'",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [{ "key": "$filter", "value": "status eq 'DONE'" }]
            },
            "description": "Valid status values: TODO, IN_PROGRESS, TEST, DONE."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('All returned tasks have status DONE', function () {",
                  "  const data = pm.response.json();",
                  "  data.value.forEach((task) => pm.expect(task.status).to.eql('DONE'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Tasks - Filter by Project",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?$filter=projectId eq '{{projectId}}'",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [{ "key": "$filter", "value": "projectId eq '{{projectId}}'" }]
            },
            "description": "Scopes the task list to a single project — this is how the frontend loads a board/list view."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('All returned tasks belong to projectId', function () {",
                  "  const data = pm.response.json();",
                  "  data.value.forEach((task) => pm.expect(task.projectId).to.eql(pm.environment.get('projectId')));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread\",\n  \"status\": \"TODO\",\n  \"dueDate\": \"2026-12-31T00:00:00.000Z\",\n  \"projectId\": \"{{projectId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] },
            "description": "ownerId is always set server-side to the authenticated user, regardless of what you send in the body. projectId is required and must be a project you own (run Projects > Create Project first)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "{",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('taskId', data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Task by Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["tasks", "{{taskId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returned task matches taskId', function () {",
                  "  pm.expect(pm.response.json().id).to.eql(pm.environment.get('taskId'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"TEST\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["tasks", "{{taskId}}"] },
            "description": "Valid status values: TODO, IN_PROGRESS, TEST, DONE. A task can also be moved to a different project you own by sending projectId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Status was updated', function () {",
                  "  pm.expect(pm.response.json().status).to.eql('TEST');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["tasks", "{{taskId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 204', function () {",
                  "  pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Error Scenarios",
      "item": [
        {
          "name": "Register Duplicate Email (409)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "description": "Reuses the seeded Alice email, which already exists, to demonstrate the 409 conflict response."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 409', function () {",
                  "  pm.response.to.have.status(409);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Tasks - No Token (401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Task - Not Found (404)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "00000000-0000-0000-0000-000000000000"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Task - Unknown Project (404)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Should fail\",\n  \"dueDate\": \"2026-12-31T00:00:00.000Z\",\n  \"projectId\": \"00000000-0000-0000-0000-000000000000\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] },
            "description": "Demonstrates that a task can't be filed under a project you don't own (or that doesn't exist)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Task - Invalid Status (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Should fail\",\n  \"status\": \"PENDING\",\n  \"dueDate\": \"2026-12-31T00:00:00.000Z\",\n  \"projectId\": \"{{projectId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] },
            "description": "PENDING was removed from the TaskStatus enum (replaced by TODO); this now fails validation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Cleanup",
      "item": [
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}"] },
            "description": "Cascades: deletes every task under this project too. Placed last (after Tasks and Error Scenarios) since both of those folders depend on {{projectId}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 204', function () {",
                  "  pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "url": { "raw": "{{serverUrl}}/health", "host": ["{{serverUrl}}"], "path": ["health"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
