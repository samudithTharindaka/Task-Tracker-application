# DIRECT_URL is only used by the Prisma CLI (generate/migrate), not the app
# at runtime. Locally both can point at the same database; in prod, point
# DATABASE_URL at your pooled connection and DIRECT_URL at the direct one.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/task_tracker?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/task_tracker?schema=public"

JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

PORT=4000

# Optional — the AI assistant endpoint (POST /api/ai/chat) returns 503 if
# this is unset, rather than the server failing to start.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
